# Whisper 模式: local (本地 mlx-whisper), openai (OpenAI API), azure (Azure OpenAI API)
WHISPER_MODE=local

# -------------------------
# Local 模式配置
# -------------------------
# Whisper 模型（用於本地 mlx-whisper）
WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# -------------------------
# OpenAI API 模式配置
# -------------------------
OPENAI_API_KEY=your_openai_api_key_here

# -------------------------
# Azure OpenAI API 模式配置
# -------------------------
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=whisper-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -------------------------
# 其他配置
# -------------------------
# Cookies 文件路徑（用於 yt-dlp 下載會員限定影片）
COOKIES_PATH=tmp/cookies.firefox-private.txt
