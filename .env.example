# ==========================================
# CUI Member Skill - 環境變數設定檔 (.env)
# ==========================================

# -------------------------
# Step 1: 下載影片配置 (yt-dlp)
# -------------------------
# 從指定瀏覽器自動讀取 Cookies（預設為 chrome，支援 firefox, edge, safari 等）
COOKIES_BROWSER=chrome
# Cookies 檔案路徑（當自動讀取失敗，需手動載入擴充功能產出的檔案時使用）
COOKIES_PATH=cookies.txt

# -------------------------
# Step 3: 語音轉文字配置 (Whisper)
# -------------------------
# Whisper 模式: local (本地端), openai (OpenAI API), azure (Azure OpenAI API)
WHISPER_MODE=local

# [Local 模式專用] Whisper 模型名稱
WHISPER_MODEL=mlx-community/whisper-medium-mlx-8bit
# WHISPER_MODEL=mlx-community/whisper-large-v3-mlx

# [OpenAI API 模式專用]
OPENAI_API_KEY=your_openai_api_key_here

# [Azure OpenAI API 模式專用]
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=whisper
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -------------------------
# Step 5: 同步至 Gist 配置 (選擇性)
# -------------------------
# 備註：若未同時填寫以下兩項，系統將自動跳過 Gist 同步功能
# GitHub Personal Access Token (需具備 gist 權限)
GITHUB_TOKEN=your_github_token_here
# 目標 Gist ID (例如 gist.github.com/username/GIST_ID 中的英數代碼)
GIST_ID=your_gist_id_here
